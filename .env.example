# Copy to .env and adjust. docker compose reads .env automatically.

KEYCLOAK_VERSION=26.1

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# The IMAGE only bakes the DB *vendor* (KC_DB=postgres, set in the Dockerfile).
# The actual *connection* is runtime config — Keycloak just points at whatever
# Postgres it's given. In qa2/prod that database is provisioned by the DBA and
# we only supply the three KC_DB_* values below (via the deployment repo's
# secret-backed values). Nothing about the real DB is ever baked into the image.

# -- Local dev (bundled throwaway Postgres in docker-compose.yml) --
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=keycloak

# -- External DB mode (point at a DBA-provided Postgres) --
# Used by docker-compose.external-db.yml. Leave blank for local bundled mode.
# KC_DB_URL=jdbc:postgresql://<dba-host>:5432/<dbname>
# KC_DB_USERNAME=<provided-by-dba>
# KC_DB_PASSWORD=<provided-by-dba>

# Bootstrap admin (created on first startup only)
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin
